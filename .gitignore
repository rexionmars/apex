# --- Build artifacts ---
/build/bin/
frontend/dist/
frontend/node_modules/

# Wails generated bindings (recreated on build)
/frontend/wailsjs/

# --- Local collection data (never versioned) ---
*.db
/data/


# --- Python sidecar caches ---
sidecar/__pycache__/
